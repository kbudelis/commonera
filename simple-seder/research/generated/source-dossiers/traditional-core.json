    {
      "id": "traditional-core-exodus-arc",
      "title": "From migration to liberation",
      "sectionIds": [
        "maggid"
      ],
      "segmentIds": [
        "research-traditional-core-16um-24a4ab7f2193",
        "research-traditional-core-17f7-1d9f8d5fc7d7",
        "research-traditional-core-198m-f4c0bfd7319f",
        "research-traditional-core-19rl-abe466be58a5",
        "research-traditional-core-1biw-ce2e6d379db2"
      ],
      "beginnerContext": "Introduce the people in the story and state the arc plainly: Jacob's family went to Egypt, grew into a people, was enslaved and harmed, cried out, and was heard. Pause after oppression before describing liberation so the emotional movement is intelligible.",
      "rationale": "These source-order passages create a usable traditional Exodus narrative across migration, population growth, forced labor, suffering, and divine response, giving a novice more than keywords without requiring the entire rabbinic exposition.",
